# ===========================================
# 校园代取系统 - 环境变量配置示例
# ===========================================
# 复制此文件为 .env.local（本地开发）或在 Vercel 控制台配置

# -------------------------------------------
# Supabase 数据库配置（必需）
# -------------------------------------------
# 从 Supabase 项目设置 > API 获取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# -------------------------------------------
# 管理员认证密钥（必需）
# -------------------------------------------
# 用于管理员接口认证，建议使用 16 位以上随机字符串
ADMIN_SECRET_KEY=your-admin-secret-key-here

# -------------------------------------------
# CORS 配置（可选）
# -------------------------------------------
# 允许的请求来源域名，多个用逗号分隔
# 留空或设置为 * 允许所有来源
ALLOWED_ORIGINS=*

# -------------------------------------------
# 前端构建配置（Vercel 自动处理）
# -------------------------------------------
# VITE_API_BASE_URL=/api
